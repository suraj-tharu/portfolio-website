// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String
  imageUrl    String?
  githubUrl   String?
  liveUrl     String?
  tags        String   // comma-separated tags
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LearningMaterial {
  id          Int      @id @default(autoincrement())
  grade       String   // e.g., "Grade 10", "Grade 12"
  category    String   @default("Course Notes") // e.g., "Course Notes", "Question Banks"
  subject     String   // e.g., "Digital Design", "OOP using C++"
  description String?
  pdfUrl      String   // URL to download the PDF
  createdAt   DateTime @default(now())
}

model TimelineEvent {
  id          Int      @id @default(autoincrement())
  year        String   // e.g., "2013 - 2017"
  role        String   // e.g., "B.E. Computer Engineering"
  location    String   // e.g., "Mid-West University"
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
}

model UploadedFile {
  id        Int      @id @default(autoincrement())
  filename  String   @unique
  mimeType  String
  content   Bytes
  createdAt DateTime @default(now())
}
