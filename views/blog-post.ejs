<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= post.title %> - Suraj Tharu Chaudhary</title>
  <meta name="description" content="<%= post.content.substring(0, 150).replace(/<[^>]*>?/gm, '') %>...">
  <meta property="og:title" content="<%= post.title %>">
  <meta property="og:description" content="<%= post.content.substring(0, 150).replace(/<[^>]*>?/gm, '') %>...">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= post.title %>">
  <meta name="twitter:description" content="<%= post.content.substring(0, 150).replace(/<[^>]*>?/gm, '') %>...">
  <link href="/dist/tailwind.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Space+Mono&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background-color: #0f172a; color: #f8fafc; }
    h1, h2, h3, h4 { font-family: 'Space Mono', monospace; font-weight: bold; }
    .prose { max-width: 65ch; margin: 0 auto; line-height: 1.7; }
    .prose p { margin-bottom: 1.5em; color: #cbd5e1; }
    .prose h1, .prose h2, .prose h3 { margin-top: 2em; margin-bottom: 1em; color: #f8fafc; }
    .prose a { color: #38bdf8; text-decoration: none; }
    .prose a:hover { text-decoration: underline; }
    .prose pre { background-color: #1e293b; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; }
    .prose code { font-family: 'Space Mono', monospace; font-size: 0.875em; }
    .prose img { max-width: 100%; height: auto; border-radius: 0.5rem; margin-top: 2em; margin-bottom: 2em; }
  </style>
</head>
<body class="bg-slate-900 text-slate-200">
  <!-- Navigation -->
  <nav class="fixed w-full z-50 top-0 transition-all duration-300 bg-slate-900/80 backdrop-blur-md border-b border-slate-800">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <a href="/#blog" class="font-bold text-2xl tracking-tighter hover:text-brand-400 transition-colors">
        ST<span class="text-brand-500">.</span>
      </a>
      <a href="/#blog" class="text-slate-400 hover:text-white transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Back to Portfolio
      </a>
    </div>
  </nav>

  <main class="pt-32 pb-20 px-6">
    <article class="max-w-3xl mx-auto">
      <header class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-white mb-6 leading-tight font-extrabold tracking-tight">
          <%= post.title %>
        </h1>
        <div class="flex items-center justify-center gap-4 text-slate-400 text-sm font-mono">
          <span>By Suraj Tharu</span>
          <span>•</span>
          <time datetime="<%= post.createdAt.toISOString() %>">
            <%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          </time>
          <% if (typeof readTime !== 'undefined') { %>
            <span>•</span>
            <span><%= readTime %> min read</span>
          <% } %>
        </div>
      </header>

      <div class="flex flex-col lg:flex-row gap-12">
        <!-- Main Content -->
        <div class="prose prose-invert prose-lg lg:w-3/4">
          <%- htmlContent %>
        </div>

        <!-- Table of Contents Sidebar -->
        <% if (typeof toc !== 'undefined' && toc.length > 0) { %>
          <aside class="lg:w-1/4">
            <div class="sticky top-24 p-6 glass-panel rounded-xl">
              <h4 class="text-brand-400 font-mono font-bold mb-4 uppercase tracking-wider text-sm">Table of Contents</h4>
              <ul class="space-y-2 text-sm text-slate-400">
                <% toc.forEach(item => { %>
                  <li style="margin-left: <%= (item.depth - 1) * 1 %>rem;">
                    <a href="#<%= item.id %>" class="hover:text-brand-500 transition-colors"><%= item.text %></a>
                  </li>
                <% }) %>
              </ul>
            </div>
          </aside>
        <% } %>
      </div>
    </article>
  </main>

  <!-- Footer -->
  <footer class="bg-slate-950 py-10 border-t border-slate-800 text-center">
    <p class="text-slate-500 font-mono text-sm">&copy; <%= new Date().getFullYear() %> Suraj Tharu Chaudhary. Built with Node.js & Prisma.</p>
  </footer>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script>hljs.highlightAll();</script>
</body>
</html>
