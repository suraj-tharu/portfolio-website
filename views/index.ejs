          <h2 class="text-3xl md:text-4xl font-bold dark:text-white text-slate-900 flex items-center gap-3">
            <span class="text-brand-400 font-mono text-4xl italic">//</span> Social Proof
          </h2>
        </div>

        <div
          class="relative w-full overflow-hidden group rounded-2xl border dark:border-slate-700 border-slate-200 bg-white dark:bg-slate-800/50 p-8 shadow-xl">
          <!-- Quote Icon -->
          <div class="absolute top-6 left-6 text-brand-500/20">
            <svg class="w-16 h-16" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>

          <div class="relative z-10 flex flex-col items-center text-center mt-4">
            <p
              class="text-lg md:text-xl font-medium dark:text-slate-300 text-slate-700 leading-relaxed italic mb-8 max-w-2xl">
              "Suraj demonstrated exceptional analytical skills during his research on LULC. His ability to apply
              machine learning to spatial datasets was instrumental to our department's remote sensing initiatives."
            </p>
            <div class="flex items-center gap-4">
              <img src="https://api.dicebear.com/7.x/initials/svg?seed=Prof&backgroundColor=0ea5e9" alt="Professor"
                class="w-12 h-12 rounded-full border-2 border-brand-500">
              <div class="text-left">
                <h4 class="font-bold dark:text-white text-slate-900">Dr. Binod Bhatta</h4>
                <div class="text-sm dark:text-slate-400 text-slate-600 font-mono">Head of GIS Dept, TU</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <!-- Section Separator -->
    <div class="section-sep" aria-hidden="true"></div>

    <section id="contact" class="py-24 relative">
      <div class="orb orb-2" style="opacity:0.08" aria-hidden="true"></div>
      <div class="max-w-4xl mx-auto px-4 text-center relative z-10" data-aos="fade-up">
        <span class="sec-num mb-4 block text-brand-400 text-sm font-mono tracking-widest uppercase neon-text">05 . Next
          Steps</span>
        <h2 class="text-4xl md:text-5xl font-extrabold dark:text-white text-slate-900 mb-6">Let's Connect</h2>
        <p class="dark:text-slate-400 text-slate-600 mb-10 max-w-lg mx-auto leading-relaxed">
          I'm currently looking for new opportunities in embedded systems, FPGA design, or hardware engineering. Whether
          you have a question or just want to say hi, my inbox is always open!
        </p>
        <button id="init-conn-btn"
          class="glow-btn inline-block px-8 py-4 bg-transparent border-2 border-brand-500 text-brand-500 hover:bg-brand-500 hover:text-white font-mono font-bold rounded-xl transition-colors">
          Initialize Connection()
        </button>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
  <footer
    class="py-8 border-t dark:border-slate-800 border-slate-200 mt-12 text-center text-sm dark:text-slate-500 text-slate-500">
    <div class="max-w-6xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-4">
      <p>&copy; <%= new Date().getFullYear() %> Suraj Tharu Chaudhary. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/surajtharu" target="_blank" class="hover:text-brand-500 transition">GitHub</a>
        <a href="https://linkedin.com/in/surajtharu" target="_blank"
          class="hover:text-brand-500 transition">LinkedIn</a>
      </div>
    </div>
  </footer>

  <!-- CHAT WIDGET -->
  <div id="chat-widget"
    class="fixed bottom-6 right-6 w-80 max-w-[calc(100vw-3rem)] dark:bg-slate-900 bg-white border dark:border-slate-700 border-slate-300 rounded-2xl shadow-2xl z-[100] flex flex-col overflow-hidden">
    <div class="px-4 py-3 bg-brand-500 text-white flex justify-between items-center">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 bg-green-300 rounded-full animate-pulse"></span>
        <span class="font-bold text-sm">Ask Suraj AI</span>
      </div>
      <button id="close-chat" class="hover:text-slate-200 transition">✕</button>
    </div>
    <div id="chat-messages" class="p-4 h-64 overflow-y-auto flex flex-col gap-3 text-sm dark:bg-slate-900 bg-slate-50">
      <div
        class="bg-slate-200 dark:bg-slate-800 p-3 rounded-xl rounded-tl-sm self-start max-w-[85%] chat-msg dark:text-slate-200 text-slate-800">
        Hi! I'm an AI assistant trained on Suraj's resume. Ask me about his FPGA experience, skills, or projects!
      </div>
    </div>
    <div class="p-3 border-t dark:border-slate-700 border-slate-200 bg-white dark:bg-slate-900 flex gap-2">
      <input type="text" id="chat-input" aria-label="Chat input"
        class="w-full bg-slate-100 dark:bg-slate-800 px-3 py-2 rounded-lg text-sm outline-none dark:text-white"
        placeholder="Type a message..." autocomplete="off">
      <button id="voice-btn"
        class="w-10 h-10 flex-shrink-0 bg-slate-200 dark:bg-slate-800 rounded-lg flex items-center justify-center hover:text-brand-500 transition"
        aria-label="Use voice">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
        </svg>
      </button>
    </div>
  </div>

  <!-- FLOATING CHAT BUTTON -->
  <button id="chat-btn"
    class="fixed bottom-6 right-6 w-14 h-14 bg-brand-500 text-white rounded-full shadow-lg flex items-center justify-center hover:bg-brand-400 transition transform hover:scale-110 z-[90]">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
    </svg>
  </button>

  <!-- GAME MODAL -->
  <div id="game-modal" class="fixed inset-0 z-[200] hidden justify-center items-center">
    <div class="absolute inset-0 bg-slate-900/80 backdrop-blur-sm" id="game-backdrop"></div>
    <div class="relative bg-slate-800 border border-brand-500 rounded-xl overflow-hidden shadow-2xl max-w-[95vw]">
      <div
        class="px-4 py-2 bg-slate-900 border-b border-brand-500 flex justify-between items-center text-brand-400 font-mono text-sm">
        <span>Score: <span id="game-score">0</span></span>
        <button id="close-game" class="hover:text-white transition">✕</button>
      </div>
      <canvas id="game-canvas" width="600" height="400"
        class="block dark:bg-[#0f172a] bg-white max-w-full h-auto"></canvas>
      <div id="game-overlay"
        class="absolute inset-0 flex items-center justify-center bg-slate-900/80 font-mono text-white text-center">
        <div>
          <h2 class="text-3xl font-bold text-brand-400 mb-2">Skill Catcher</h2>
          <p class="mb-4 text-slate-300">Use <kbd class="bg-slate-700 px-2 py-1 rounded">⬅️</kbd> <kbd
              class="bg-slate-700 px-2 py-1 rounded">➡️</kbd> Arrow Keys to catch falling skills!</p>
          <button id="start-game-btn"
            class="px-6 py-2 bg-brand-500 rounded-lg hover:bg-brand-400 transition font-bold shadow-lg shadow-brand-500/20">Start
            Game</button>
        </div>
      </div>
    </div>
  </div>

  <!-- CONTACT MODAL -->
  <div id="contact-modal" class="fixed inset-0 z-[200] hidden justify-center items-center">
    <div class="absolute inset-0 dark:bg-[#060b13]/80 bg-slate-900/40 backdrop-blur-md" id="contact-backdrop"></div>
    <div
      class="relative w-full max-w-2xl dark:bg-[#0f172a] bg-white border dark:border-[#1e293b] border-slate-200 rounded-xl shadow-[0_0_40px_rgba(14,165,233,0.15)] overflow-hidden font-mono mx-4 transform scale-95 opacity-0 transition-all duration-300"
      id="contact-box">
      <!-- Terminal Header -->
      <div
        class="flex items-center px-4 py-3 dark:bg-[#0b1121] bg-slate-100 border-b dark:border-[#1e293b] border-slate-200">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
          <div class="w-3 h-3 rounded-full bg-green-500"></div>
        </div>
        <div class="mx-auto text-xs text-slate-400">contact.sh</div>
        <button id="close-contact" class="text-slate-400 hover:text-white absolute right-4 transition">✕</button>
      </div>
      <!-- Terminal Body -->
      <div class="p-6 text-sm text-slate-300">
        <div class="mb-6 flex items-center gap-2">
          <span class="text-green-400">user@contact:~$</span> <span class="text-slate-100">compose message<span
              class="animate-pulse">_</span></span>
        </div>

        <form id="contact-form" class="space-y-5">
          <div>
            <label for="c-name" class="block mb-2 text-slate-300">Name</label>
            <input type="text" id="c-name" required
              class="w-full dark:bg-[#1e293b]/50 bg-slate-100 border dark:border-[#334155] border-slate-300 rounded-lg px-4 py-2.5 dark:text-white text-slate-900 focus:outline-none focus:border-[#38bdf8] transition-colors">
          </div>
          <div>
            <label for="c-email" class="block mb-2 text-slate-300">Email</label>
            <input type="email" id="c-email" required
              class="w-full dark:bg-[#1e293b]/50 bg-slate-100 border dark:border-[#334155] border-slate-300 rounded-lg px-4 py-2.5 dark:text-white text-slate-900 focus:outline-none focus:border-[#38bdf8] transition-colors">
          </div>
          <div>
            <label for="c-subject" class="block mb-2 text-slate-300">Subject</label>
            <input type="text" id="c-subject"
              class="w-full dark:bg-[#1e293b]/50 bg-slate-100 border dark:border-[#334155] border-slate-300 rounded-lg px-4 py-2.5 dark:text-white text-slate-900 focus:outline-none focus:border-[#38bdf8] transition-colors">
          </div>
          <div>
            <label for="c-msg" class="block mb-2 text-slate-300">Message</label>
            <input type="text" name="honeypot" id="c-hp" style="display:none" tabindex="-1" autocomplete="off"
              aria-label="Honeypot">
            <textarea id="c-msg" required rows="4"
              class="w-full dark:bg-[#1e293b]/50 bg-slate-100 border dark:border-[#334155] border-slate-300 rounded-lg px-4 py-2.5 dark:text-white text-slate-900 focus:outline-none focus:border-[#38bdf8] transition-colors"></textarea>
          </div>
          <button type="submit"
            class="w-full bg-[#0ea5e9] hover:bg-[#38bdf8] text-white font-bold py-3 rounded-lg transition-colors mt-4">
            Execute Send
          </button>
        </form>
        <div id="contact-status" class="mt-4 hidden text-center font-bold"></div>
      </div>
    </div>
  </div>

  <!-- COMMAND PALETTE MODAL -->
  <div id="cmd-palette" class="fixed inset-0 z-[200] hidden justify-center items-start pt-[15vh]">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" id="cmd-backdrop"></div>
    <div
      class="relative w-full max-w-xl bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-2xl shadow-2xl overflow-hidden chat-msg">
      <div class="flex items-center px-4 py-3 border-b dark:border-slate-700">
        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" id="cmd-input" aria-label="Command search"
          class="w-full bg-transparent border-none outline-none px-3 text-lg dark:text-white"
          placeholder="Search commands, sections, or type 'help'..." autocomplete="off">
        <button id="cmd-close"
          class="text-xs font-mono bg-slate-200 dark:bg-slate-800 px-2 py-1 rounded text-slate-500 hover:bg-slate-300 dark:hover:bg-slate-700 transition">ESC</button>
      </div>
      <div class="max-h-64 overflow-y-auto p-2" id="cmd-results">
        <!-- Results injected via JS -->
      </div>
    </div>
  </div>

  <div id="a11y-menu"
    class="hidden fixed top-20 right-4 w-64 bg-white dark:bg-slate-900 border dark:border-slate-700 rounded-2xl shadow-2xl p-4 z-[100] flex-col gap-3 chat-msg">
    <h3 class="text-sm font-bold border-b pb-2 dark:border-slate-700 dark:text-white">Accessibility</h3>
    <label for="a11y-motion" class="flex items-center justify-between text-sm cursor-pointer dark:text-slate-300">
      <span>Reduce Motion</span>
      <input type="checkbox" id="a11y-motion"
        class="form-checkbox text-brand-500 rounded bg-slate-800 border-slate-700">
    </label>
    <label for="a11y-contrast" class="flex items-center justify-between text-sm cursor-pointer dark:text-slate-300">
      <span>High Contrast</span>
      <input type="checkbox" id="a11y-contrast"
        class="form-checkbox text-brand-500 rounded bg-slate-800 border-slate-700">
    </label>
    <label for="a11y-font" class="flex items-center justify-between text-sm cursor-pointer dark:text-slate-300">
      <span>Dyslexia Font</span>
      <input type="checkbox" id="a11y-font" class="form-checkbox text-brand-500 rounded bg-slate-800 border-slate-700">
    </label>
  </div>

  <!-- Socket.io for Real-Time Visitor Counter & Cursors -->
  <script src="/socket.io/socket.io.js"></script>

  <!-- bundle.js is deferred so it runs AFTER all synchronous CDN scripts above have executed -->
  <script src="/dist/bundle.js" defer></script>
</body>

</html>