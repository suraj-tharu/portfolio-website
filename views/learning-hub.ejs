<!DOCTYPE html>
<html lang="en" class="dark scroll-smooth">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Learning Hub | Suraj Tharu Chaudhary</title>
  <meta name="description" content="Digital Classroom and Learning Hub by Suraj Tharu Chaudhary.">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎓</text></svg>">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">

  <!-- Built Tailwind CSS -->
  <link rel="stylesheet" href="/dist/tailwind.css">
  <link rel="stylesheet" href="/style.css">
</head>

<body class="dark:text-slate-300 text-slate-800 font-sans antialiased bg-custom-background">
  <!-- NAVIGATION -->
  <nav class="fixed top-0 w-full z-50 glass-panel border-b-0" id="main-nav">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
      <a href="/" class="font-mono font-bold text-lg dark:text-white text-slate-900">&lt;Er.Suraj /&gt;</a>
      <div class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm hover:text-brand-400 transition">Home</a>
        <a href="/learning-hub" class="text-sm text-brand-400 transition font-bold">Learning Hub</a>
      </div>
    </div>
  </nav>

  <main class="pt-24 pb-20">
    <div class="max-w-5xl mx-auto px-4">
      <div class="mb-12 text-center" data-aos="fade-up">
        <h1 class="text-4xl md:text-5xl font-bold text-custom-primary mb-4 flex items-center justify-center gap-3">
          <span class="text-custom-accent">🎓</span> Digital Classroom
        </h1>
        <p class="text-custom-secondary max-w-2xl mx-auto text-lg">
          Welcome to the Learning Hub. Access comprehensive notes, practical files, and teacher training resources designed to enhance ICT integration in education.
        </p>
      </div>

      <div class="space-y-12">
        <% const categories = ["Grade 10", "Grade 11", "Grade 12", "Teacher Training"]; %>
        <% categories.forEach((category, index) => { %>
          <% const categoryMaterials = materials.filter(m => m.grade === category); %>
          <% if (categoryMaterials.length > 0) { %>
            <section class="glass-card p-8 rounded-2xl border border-glass-border">
              <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
                <span class="text-custom-accent font-mono"><%= String(index + 1).padStart(2, '0') %> //</span> <%= category %>
              </h2>
              <div class="grid md:grid-cols-2 gap-4">
                <% categoryMaterials.forEach(m => { %>
                  <div class="bg-custom-surface/50 p-4 rounded-xl border border-glass-border flex items-center justify-between group hover:border-custom-primary transition">
                    <div>
                      <h3 class="font-bold text-custom-primary"><%= m.subject %></h3>
                      <p class="text-sm text-custom-secondary"><%= m.description || 'No description provided' %></p>
                    </div>
                    <a href="<%= m.pdfUrl %>" target="_blank" class="px-4 py-2 bg-custom-primary/10 text-custom-primary rounded-lg font-mono text-sm hover:bg-custom-primary hover:text-custom-background transition shrink-0 ml-4">PDF ↓</a>
                  </div>
                <% }) %>
              </div>
            </section>
          <% } %>
        <% }) %>

        <% if (!materials || materials.length === 0) { %>
          <div class="text-center py-20 text-custom-secondary glass-card rounded-2xl border border-glass-border">
            <p class="text-xl mb-4">No learning materials have been added yet.</p>
            <p>Check back soon, or login to the admin panel to add some!</p>
          </div>
        <% } %>

      </div>
    </div>
  </main>

  <footer class="py-8 border-t border-glass-border bg-custom-background/80 text-center">
    <p class="text-custom-secondary text-sm font-mono">&copy; <%= new Date().getFullYear() %> Suraj Tharu Chaudhary. All rights reserved.</p>
  </footer>

</body>
</html>
