          <div><label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Year(s)</label><input type="text" name="year" required class="premium-input text-sm"></div>
          <div><label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Role</label><input type="text" name="role" required class="premium-input text-sm"></div>
          <div><label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Location</label><input type="text" name="location" required class="premium-input text-sm"></div>
          <div><label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Order Index</label><input type="number" name="orderIndex" value="0" required class="premium-input text-sm"></div>
        </div>
        <div class="mt-8 flex justify-end">
          <button type="submit" class="premium-button bg-emerald-500 border-transparent text-white hover:bg-emerald-400 py-2 shadow-[0_0_20px_rgba(16,185,129,0.3)]">Save Event</button>
        </div>
      </form>

      <!-- List -->
      <div class="grid md:grid-cols-2 gap-4">
        <% timelineEvents.forEach(t=> { %>
          <div class="premium-card p-5 flex justify-between group hover:border-emerald-500/40">
            <div>
              <span class="text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded-full uppercase font-bold tracking-wider mb-2 inline-block"><%= t.year %></span>
