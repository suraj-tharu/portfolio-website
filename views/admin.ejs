  <script>
    let simplemde = null;

    document.addEventListener("DOMContentLoaded", function () {
      
      // Setup Search Filters
      function setupSearch(inputId, listId) {
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);
        if(!input || !list) return;
        
        input.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          const items = list.children;
          Array.from(items).forEach(item => {
            const data = item.getAttribute('data-search') || '';
            if (data.includes(query)) {
              item.style.display = 'flex';
            } else {
              item.style.display = 'none';
            }
          });
        });
      }
      
      setupSearch('search-projects', 'projects-list');
      setupSearch('search-blogs', 'blogs-list');
      setupSearch('search-learning', 'learning-list');

      // Tab Switching Logic
      const navBtns = document.querySelectorAll('.nav-btn');
      const tabContents = document.querySelectorAll('.tab-content');
      
      function setActiveTab(tabId) {
        navBtns.forEach(btn => {
          btn.classList.remove('text-brand', 'bg-brand/10', 'border-brand/20');
          btn.classList.add('text-text-secondary', 'border-transparent', 'hover:bg-surface-2', 'hover:text-text-primary');
        });
        
        tabContents.forEach(content => { content.classList.remove('active'); });
        
        const activeBtn = document.querySelector(`.nav-btn[data-tab="${tabId}"]`);
        if (activeBtn) {
          activeBtn.classList.remove('text-text-secondary', 'border-transparent', 'hover:bg-surface-2', 'hover:text-text-primary');
          activeBtn.classList.add('text-brand', 'bg-brand/10', 'border-brand/20');
        }
        
        const activeContent = document.getElementById(tabId);
        if (activeContent) { activeContent.classList.add('active'); }
        
        document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth' });
        closeSidebar();
      }

      navBtns.forEach(btn => {
        btn.addEventListener('click', () => { setActiveTab(btn.dataset.tab); });
      });

      // Mobile Sidebar Toggle
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      
      function openSidebar() {
        sidebar.classList.remove('hidden');
        sidebar.classList.remove('-translate-x-full');
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      
      function closeSidebar() {
        if(window.innerWidth < 768) {
          sidebar.classList.add('-translate-x-full');
          setTimeout(() => { sidebar.classList.add('hidden'); }, 300);
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }
      
      mobileBtn.addEventListener('click', openSidebar);
      overlay.addEventListener('click', closeSidebar);
      
      if(window.innerWidth < 768) { sidebar.classList.add('-translate-x-full'); }
      
      window.addEventListener('resize', () => {
        if(window.innerWidth >= 768) {
          sidebar.classList.remove('hidden', '-translate-x-full');
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        } else if (!overlay.classList.contains('hidden')) {
        } else {
          sidebar.classList.add('hidden', '-translate-x-full');
        }
      });
    });

    // Modal Logic
    function openModal(modalId, data) {
      document.getElementById('modal-backdrop').classList.remove('hidden');
      const modal = document.getElementById(modalId);
      modal.classList.remove('hidden');
      
      // Populate logic
      if (modalId === 'project-modal') {
        const form = document.getElementById('project-form');
        if (data) {
          document.getElementById('project-modal-title').innerText = 'Edit Project';
          form.action = `/admin/api/projects/${data.id}/update`;
          document.getElementById('p-title').value = data.title;
          document.getElementById('p-imageUrl').value = data.imageUrl || '';
          document.getElementById('p-description').value = data.description;
          document.getElementById('p-liveUrl').value = data.liveUrl || '';
          document.getElementById('p-tags').value = data.tags || '';
        } else {
          document.getElementById('project-modal-title').innerText = 'Add Project';
          form.action = `/admin/api/projects`;
          form.reset();
        }
      } else if (modalId === 'blog-modal') {
        const form = document.getElementById('blog-form');
        if (data) {
          document.getElementById('blog-modal-title').innerText = 'Edit Blog';
          form.action = `/admin/api/blogs/${data.id}/update`;
          document.getElementById('b-title').value = data.title;
          document.getElementById('b-slug').value = data.slug;
          document.getElementById('b-published').checked = data.published;
          document.getElementById('b-content').value = data.content;
        } else {
          document.getElementById('blog-modal-title').innerText = 'Add Blog';
          form.action = `/admin/api/blogs`;
          form.reset();
        }
        // Initialize or Update SimpleMDE
        if (!simplemde) {
          simplemde = new SimpleMDE({ element: document.getElementById("b-content"), spellChecker: false });
        }
        simplemde.value(data ? data.content : '');
      } else if (modalId === 'learning-modal') {
        const form = document.getElementById('learning-form');
        if (data) {
          document.getElementById('learning-modal-title').innerText = 'Edit Resource';
          form.action = `/admin/api/learning-materials/${data.id}/update`;
          document.getElementById('l-grade').value = data.grade;
          document.getElementById('l-category').value = data.category || 'Course Notes';
          document.getElementById('l-subject').value = data.subject;
          document.getElementById('l-description').value = data.description || '';
          document.getElementById('l-pdfUrl').value = data.pdfUrl || '';
        } else {
          document.getElementById('learning-modal-title').innerText = 'Add Resource';
          form.action = `/admin/api/learning-materials`;
          form.reset();
        }
      } else if (modalId === 'timeline-modal') {
        const form = document.getElementById('timeline-form');
        if (data) {
          document.getElementById('timeline-modal-title').innerText = 'Edit Event';
          form.action = `/admin/api/timeline/${data.id}/update`;
          document.getElementById('t-year').value = data.year;
          document.getElementById('t-role').value = data.role;
          document.getElementById('t-location').value = data.location;
          document.getElementById('t-orderIndex').value = data.orderIndex;
        } else {
          document.getElementById('timeline-modal-title').innerText = 'Add Event';
          form.action = `/admin/api/timeline`;
          form.reset();
        }
      }
    }

    function closeModal() {
      document.getElementById('modal-backdrop').classList.add('hidden');
      document.querySelectorAll('.modal-content').forEach(m => m.classList.add('hidden'));
    }
  </script>
</body>
</html>