        </div>
        <div class="mt-10 flex justify-end gap-4">
          <button type="button" onclick="closeModal()" class="px-6 py-3 rounded-xl font-bold text-white/60 hover:text-white hover:bg-white/10 transition-colors text-sm">Cancel</button>
          <button type="submit" class="btn-gradient-blue text-white font-bold py-3 px-8 rounded-xl text-sm">Save Changes</button>
        </div>
      </form>
    </div>

    <!-- Timeline Modal -->
    <div id="timeline-modal" class="modal-content premium-card w-full max-w-2xl max-h-[90vh] overflow-y-auto hidden">
      <form id="timeline-form" method="POST" class="p-8">
        <div class="flex justify-between items-center mb-8 border-b border-white/10 pb-4">
          <h3 id="timeline-modal-title" class="text-2xl font-black text-white">Edit Event</h3>
          <button type="button" onclick="closeModal()" class="text-white/40 hover:text-white p-2 rounded-lg hover:bg-white/10 transition-colors"><svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg></button>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          <div><label class="block text-[10px] text-white/50 mb-2 uppercase tracking-widest font-bold">Year(s)</label><input type="text" name="year" id="t-year" required class="premium-input text-sm"></div>
          <div><label class="block text-[10px] text-white/50 mb-2 uppercase tracking-widest font-bold">Order Index</label><input type="number" name="orderIndex" id="t-orderIndex" required class="premium-input text-sm"></div>
          <div><label class="block text-[10px] text-white/50 mb-2 uppercase tracking-widest font-bold">Role</label><input type="text" name="role" id="t-role" required class="premium-input text-sm"></div>
          <div><label class="block text-[10px] text-white/50 mb-2 uppercase tracking-widest font-bold">Location</label><input type="text" name="location" id="t-location" required class="premium-input text-sm"></div>
        </div>
        <div class="mt-10 flex justify-end gap-4">
          <button type="button" onclick="closeModal()" class="px-6 py-3 rounded-xl font-bold text-white/60 hover:text-white hover:bg-white/10 transition-colors text-sm">Cancel</button>
          <button type="submit" class="btn-gradient-emerald text-white font-bold py-3 px-8 rounded-xl text-sm">Save Changes</button>
        </div>
      </form>
    </div>

  </div>

  <script>
    let simplemde = null;

    document.addEventListener("DOMContentLoaded", function () {
      
      // Setup Search Filters
      function setupSearch(inputId, listId) {
        const input = document.getElementById(inputId);
        const list = document.getElementById(listId);
        if(!input || !list) return;
        
        input.addEventListener('input', (e) => {
          const query = e.target.value.toLowerCase();
          const items = list.children;
          Array.from(items).forEach(item => {
            const data = item.getAttribute('data-search') || '';
            if (data.includes(query)) {
              item.style.display = 'flex';
            } else {
              item.style.display = 'none';
            }
          });
        });
      }
      
      setupSearch('search-projects', 'projects-list');
      setupSearch('search-blogs', 'blogs-list');
      setupSearch('search-learning', 'learning-list');

      // Initialize SimpleMDE for the Add Blog form
      if(document.getElementById("blog-add-editor")) {
        new SimpleMDE({
          element: document.getElementById("blog-add-editor"),
          spellChecker: false,
          placeholder: "Write your amazing blog post here in Markdown..."
        });
      }
    });

    // Modal Logic for Editing
    function openModal(modalId, data) {
      document.getElementById('modal-backdrop').classList.remove('hidden');
      const modal = document.getElementById(modalId);
      modal.classList.remove('hidden');
      
      // Populate logic
      if (modalId === 'project-modal') {
        const form = document.getElementById('project-form');
        if (data) {
          form.action = `/admin/api/projects/${data.id}/update`;
          document.getElementById('p-title').value = data.title;
          document.getElementById('p-imageUrl').value = data.imageUrl || '';
          document.getElementById('p-description').value = data.description;
          document.getElementById('p-liveUrl').value = data.liveUrl || '';
          document.getElementById('p-tags').value = data.tags || '';
        }
      } else if (modalId === 'blog-modal') {
        const form = document.getElementById('blog-form');
        if (data) {
          form.action = `/admin/api/blogs/${data.id}/update`;
          document.getElementById('b-title').value = data.title;
          document.getElementById('b-slug').value = data.slug;
          document.getElementById('b-published-edit').checked = data.published;
          document.getElementById('b-content').value = data.content;
        }
        // Initialize or Update SimpleMDE for Edit Modal
        if (!simplemde) {
          simplemde = new SimpleMDE({ element: document.getElementById("b-content"), spellChecker: false });
        }
        simplemde.value(data ? data.content : '');
      } else if (modalId === 'learning-modal') {
        const form = document.getElementById('learning-form');
        if (data) {
          form.action = `/admin/api/learning-materials/${data.id}/update`;
          document.getElementById('l-grade').value = data.grade;
          document.getElementById('l-category').value = data.category || 'Course Notes';
          document.getElementById('l-subject').value = data.subject;
          document.getElementById('l-description').value = data.description || '';
          document.getElementById('l-pdfUrl').value = data.pdfUrl || '';
        }
      } else if (modalId === 'timeline-modal') {
        const form = document.getElementById('timeline-form');
        if (data) {
          form.action = `/admin/api/timeline/${data.id}/update`;
          document.getElementById('t-year').value = data.year;
          document.getElementById('t-role').value = data.role;
          document.getElementById('t-location').value = data.location;
          document.getElementById('t-orderIndex').value = data.orderIndex;
        }
      }
    }

    function closeModal() {
      document.getElementById('modal-backdrop').classList.add('hidden');
      document.querySelectorAll('.modal-content').forEach(m => m.classList.add('hidden'));
    }
  </script>
</body>
</html>