<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Suraj's Portfolio</title>
  <link href="/dist/tailwind.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.css">
  <script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>
  <style>
    body {
      background-color: var(--bg, #06080F);
      color: var(--text, #F0F2F8);
      font-family: 'Inter', sans-serif;
    }
    
    /* SimpleMDE Premium Dark Theme */
    .editor-toolbar {
      background-color: var(--surface-2, #151B28) !important;
      border-color: var(--stroke, #1E293B) !important;
      border-top-left-radius: 0.5rem;
      border-top-right-radius: 0.5rem;
      opacity: 1 !important;
    }
    .editor-toolbar a {
      color: var(--text-secondary, #A8B2D1) !important;
    }
    .editor-toolbar a:hover,
    .editor-toolbar a.active {
      background-color: var(--stroke-strong, #334155) !important;
      border-color: transparent !important;
      color: var(--text, #FFF) !important;
    }
    .CodeMirror {
      background-color: var(--surface, #0D1117) !important;
      color: var(--text, #e2e8f0) !important;
      border-color: var(--stroke, #1E293B) !important;
      border-bottom-left-radius: 0.5rem;
      border-bottom-right-radius: 0.5rem;
    }
    .editor-preview {
      background-color: var(--surface, #0D1117);
      color: var(--text, #e2e8f0);
    }
    
    /* Hide scrollbar for sidebar */
    .no-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .no-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    /* Tab Transitions */
    .tab-content {
      display: none;
      animation: fadeIn 0.4s ease forwards;
    }
    .tab-content.active {
      display: block;
    }
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body class="bg-bg font-sans min-h-screen overflow-hidden flex flex-col md:flex-row">

  <!-- Mobile Topbar -->
  <header class="md:hidden bg-surface border-b border-stroke p-4 flex justify-between items-center z-50">
    <div class="font-mono text-lg font-bold text-text-primary">
      Admin<span class="text-brand">Dashboard</span>
    </div>
    <div class="flex items-center gap-4">
      <a href="/" class="text-text-secondary hover:text-brand transition text-sm">View Site</a>
      <button id="mobile-menu-btn" class="text-text-primary focus:outline-none">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </header>

  <!-- Sidebar -->
  <aside id="sidebar" class="hidden md:flex flex-col w-full md:w-64 bg-surface border-r border-stroke z-40 fixed md:relative h-[calc(100vh-60px)] md:h-screen top-[60px] md:top-0 left-0 transition-transform transform md:translate-x-0 overflow-y-auto no-scrollbar">
    <div class="hidden md:flex p-6 font-mono text-xl font-bold border-b border-stroke text-text-primary sticky top-0 bg-surface z-10">
      Admin<span class="text-brand">Dashboard</span>
    </div>
    
    <nav class="flex-1 p-4 space-y-2">
      <button data-tab="projects" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left text-sm font-medium text-brand bg-brand/10 transition-all border border-brand/20">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Projects
      </button>
      <button data-tab="blogs" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-2 transition-all border border-transparent">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm-5-9h10v2H7z"/></svg>
        Blog Posts
      </button>
      <button data-tab="learning" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-2 transition-all border border-transparent">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M13 13H3v-2h10v2zm0-4H3V7h10v2zm0 8H3v-2h10v2zm8-8v4h4v-4h-4z"/></svg>
        Learning Hub
      </button>
      <button data-tab="timeline" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-2 transition-all border border-transparent">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/></svg>
        Timeline
      </button>
      <button data-tab="messages" class="nav-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-left text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-2 transition-all border border-transparent relative">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
        Inbox
        <% if (messages.length > 0) { %>
          <span class="absolute right-4 top-1/2 -translate-y-1/2 bg-brand text-white text-[10px] font-bold px-2 py-0.5 rounded-full"><%= messages.length %></span>
        <% } %>
      </button>
    </nav>
    
    <div class="p-4 border-t border-stroke mt-auto space-y-3">
      <a href="/" class="hidden md:flex w-full items-center justify-center gap-2 px-4 py-2 rounded-lg text-sm text-text-secondary hover:text-text-primary hover:bg-surface-2 transition">
        View Live Site
      </a>
      <a href="/admin/logout" class="premium-button w-full border-red-500/20 text-red-400 hover:border-red-500 hover:text-white hover:bg-red-500/10 transition-colors py-2 text-sm shadow-none font-semibold">
        Log Out
      </a>
    </div>
  </aside>

  <!-- Main Content Area -->
  <main class="flex-1 overflow-y-auto p-4 md:p-8 bg-bg relative h-[calc(100vh-60px)] md:h-screen">
    
    <!-- ════════════════════════════════════════════════════════════
         PROJECTS SECTION
    ════════════════════════════════════════════════════════════ -->
    <div id="projects" class="tab-content active max-w-5xl mx-auto space-y-8 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-text-primary">Projects & Research</h1>
      </div>

      <!-- Add Form -->
      <form action="/admin/api/projects" method="POST" enctype="multipart/form-data" class="premium-card p-6 md:p-8 relative">
        <div class="absolute top-0 left-0 w-1 h-full bg-brand rounded-l-lg"></div>
        <h3 class="text-lg font-bold text-text-primary mb-6 flex items-center gap-2">Add New Project</h3>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Title</label>
            <input type="text" name="title" required class="premium-input text-sm">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Image URL (Or upload)</label>
            <input type="url" name="imageUrl" class="premium-input text-sm mb-3">
            <input type="file" name="imageFile" accept="image/*" class="w-full text-sm text-text-secondary file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-brand/10 file:text-brand hover:file:bg-brand/20 transition cursor-pointer">
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Description</label>
            <textarea name="description" required rows="2" class="premium-input text-sm"></textarea>
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Live URL</label>
            <input type="url" name="liveUrl" class="premium-input text-sm">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Tags (Comma separated)</label>
            <input type="text" name="tags" placeholder="React, Node, QGIS" class="premium-input text-sm">
          </div>
        </div>
        <div class="mt-8 flex justify-end">
          <button type="submit" class="premium-button bg-brand border-transparent text-white hover:bg-brand-light brand-glow py-2.5">
            Create Project
          </button>
        </div>
      </form>

      <!-- List -->
      <div class="grid gap-4">
        <h3 class="text-sm font-bold text-text-secondary uppercase tracking-wider mb-2 mt-4">Existing Projects (<%= projects.length %>)</h3>
        <% projects.forEach(p=> { %>
          <div class="premium-card p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 group hover:border-brand/40">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 rounded-xl bg-surface-2 flex-shrink-0 overflow-hidden border border-stroke">
                <% if (p.imageUrl) { %>
                  <img src="<%= p.imageUrl %>" alt="Thumbnail" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-muted">
                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                  </div>
                <% } %>
              </div>
              <div>
                <h4 class="font-bold text-text-primary text-lg group-hover:text-brand transition-colors"><%= p.title %></h4>
                <div class="flex flex-wrap gap-2 mt-2">
                  <% p.tags.split(',').forEach(tag => { %>
                    <span class="text-[10px] px-2 py-0.5 rounded bg-surface-2 text-text-secondary border border-stroke"><%= tag.trim() %></span>
                  <% }) %>
                </div>
              </div>
            </div>
            <form action="/admin/api/projects/<%= p.id %>/delete" method="POST" onsubmit="return confirm('Delete this project?');" class="sm:shrink-0 flex justify-end">
              <button type="submit" class="text-xs font-semibold px-3 py-2 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-colors">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>


    <!-- ════════════════════════════════════════════════════════════
         BLOG POSTS SECTION
    ════════════════════════════════════════════════════════════ -->
    <div id="blogs" class="tab-content max-w-5xl mx-auto space-y-8 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-text-primary">Blog Posts</h1>
      </div>

      <!-- Add Form -->
      <form action="/admin/api/blogs" method="POST" enctype="multipart/form-data" class="premium-card p-6 md:p-8 relative">
        <div class="absolute top-0 left-0 w-1 h-full bg-pink-500 rounded-l-lg"></div>
        <h3 class="text-lg font-bold text-text-primary mb-6 flex items-center gap-2">Write New Post</h3>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Title</label>
            <input type="text" name="title" required class="premium-input text-sm">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Slug (URL)</label>
            <input type="text" name="slug" required class="premium-input text-sm" placeholder="my-awesome-post">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Cover Image</label>
            <input type="file" name="imageFile" accept="image/*" class="w-full text-sm text-text-secondary file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-pink-500/10 file:text-pink-500 hover:file:bg-pink-500/20 transition cursor-pointer">
          </div>
          <div class="flex items-center gap-3">
            <div class="flex items-center h-5">
              <input type="checkbox" name="published" id="published" class="w-5 h-5 rounded border-stroke bg-surface focus:ring-pink-500 text-pink-500 cursor-pointer" checked>
            </div>
            <label for="published" class="text-sm font-semibold text-text-primary cursor-pointer">Publish immediately</label>
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Content (Markdown)</label>
            <textarea name="content" id="blog-content-editor" required rows="6"></textarea>
          </div>
        </div>
        <div class="mt-8 flex justify-end">
          <button type="submit" class="premium-button bg-pink-500 border-transparent text-white hover:bg-pink-400 py-2.5 shadow-[0_0_20px_rgba(236,72,153,0.3)]">
            Create Post
          </button>
        </div>
      </form>

      <!-- List -->
      <div class="grid gap-4">
        <h3 class="text-sm font-bold text-text-secondary uppercase tracking-wider mb-2 mt-4">Existing Posts (<%= blogs.length %>)</h3>
        <% blogs.forEach(b=> { %>
          <div class="premium-card p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4 group hover:border-pink-500/40">
            <div class="flex items-center gap-4">
              <div class="w-16 h-16 rounded-xl bg-surface-2 flex-shrink-0 overflow-hidden border border-stroke">
                <% if (b.imageUrl) { %>
                  <img src="<%= b.imageUrl %>" alt="Thumbnail" class="w-full h-full object-cover">
                <% } else { %>
                  <div class="w-full h-full flex items-center justify-center text-muted font-mono text-[10px]">No Img</div>
                <% } %>
              </div>
              <div>
                <div class="flex items-center gap-3">
                  <h4 class="font-bold text-text-primary text-lg group-hover:text-pink-400 transition-colors"><%= b.title %></h4>
                  <% if (!b.published) { %>
                    <span class="text-[10px] bg-yellow-500/10 text-yellow-500 border border-yellow-500/20 px-2 py-0.5 rounded-full font-bold uppercase tracking-wide">Draft</span>
                  <% } %>
                </div>
                <div class="text-xs text-text-secondary mt-1 font-mono">/<%= b.slug %> &bull; <%= new Date(b.createdAt).toLocaleDateString() %></div>
              </div>
            </div>
            <form action="/admin/api/blogs/<%= b.id %>/delete" method="POST" onsubmit="return confirm('Delete this post?');" class="sm:shrink-0 flex justify-end">
              <button type="submit" class="text-xs font-semibold px-3 py-2 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-colors">Delete</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>


    <!-- ════════════════════════════════════════════════════════════
         LEARNING HUB SECTION
    ════════════════════════════════════════════════════════════ -->
    <div id="learning" class="tab-content max-w-5xl mx-auto space-y-8 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-text-primary">Learning Hub Resources</h1>
      </div>

      <!-- Add Form -->
      <form action="/admin/api/learning-materials" method="POST" enctype="multipart/form-data" class="premium-card p-6 md:p-8 relative">
        <div class="absolute top-0 left-0 w-1 h-full bg-blue-500 rounded-l-lg"></div>
        <h3 class="text-lg font-bold text-text-primary mb-6 flex items-center gap-2">Upload Resource</h3>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">📚 Grade / Group</label>
            <select name="grade" required class="premium-input text-sm cursor-pointer">
              <option value="Grade 10">Grade 10</option>
              <option value="Grade 11">Grade 11</option>
              <option value="Grade 12">Grade 12</option>
              <option value="Teacher Training">Teacher Training</option>
            </select>
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">📂 Category</label>
            <select name="category" required class="premium-input text-sm cursor-pointer">
              <option value="Course Notes">Course Notes</option>
              <option value="Question Banks">Question Banks</option>
              <option value="Syllabus">Syllabus</option>
              <option value="Lab Manuals">Lab Manuals</option>
              <option value="Reference Materials">Reference Materials</option>
            </select>
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Subject Title</label>
            <input type="text" name="subject" required class="premium-input text-sm" placeholder="e.g. Digital Design">
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Description</label>
            <input type="text" name="description" class="premium-input text-sm" placeholder="Brief context...">
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-3 uppercase tracking-wide font-semibold">📁 Upload File (PDF/DOC)</label>
            <div class="relative">
              <input type="file" name="pdfFile" accept=".pdf,.doc,.docx" class="hidden" id="file-upload">
              <label for="file-upload" class="flex flex-col items-center justify-center w-full p-8 border-2 border-dashed border-stroke bg-surface-2 rounded-xl cursor-pointer hover:border-blue-500 hover:bg-blue-500/5 transition group">
                <div class="w-12 h-12 rounded-full bg-surface border border-stroke flex items-center justify-center mb-3 group-hover:bg-blue-500/10 group-hover:border-blue-500/30 group-hover:text-blue-400 transition-colors">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                </div>
                <p class="text-sm font-bold text-text-primary">Click to browse or drop file</p>
                <p class="text-xs text-muted mt-1">PDF, DOC, DOCX up to 50MB</p>
              </label>
            </div>
          </div>
          <div class="md:col-span-2">
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">OR External URL</label>
            <input type="url" name="pdfUrl" class="premium-input text-sm" placeholder="https://drive.google.com/...">
          </div>
        </div>
        <div class="mt-8 flex justify-end">
          <button type="submit" class="premium-button bg-blue-500 border-transparent text-white hover:bg-blue-400 py-2.5 shadow-[0_0_20px_rgba(59,130,246,0.3)]">
            Upload Resource
          </button>
        </div>
      </form>

      <!-- List -->
      <div class="grid md:grid-cols-2 gap-4">
        <% learningMaterials.forEach(m=> { %>
          <div class="premium-card p-5 flex flex-col justify-between group hover:border-blue-500/40">
            <div>
              <div class="flex items-start justify-between mb-4">
                <div class="flex flex-wrap gap-2">
                  <span class="text-[10px] bg-blue-500/10 text-blue-400 border border-blue-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-wider"><%= m.grade %></span>
                  <span class="text-[10px] bg-purple-500/10 text-purple-400 border border-purple-500/20 px-2 py-0.5 rounded uppercase font-bold tracking-wider"><%= m.category || 'Course Notes' %></span>
                </div>
                <form action="/admin/api/learning-materials/<%= m.id %>/delete" method="POST" onsubmit="return confirm('Delete this resource?');">
                  <button type="submit" class="text-xs font-semibold px-2 py-1 rounded bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-colors">✕</button>
                </form>
              </div>
              <h3 class="font-bold text-text-primary text-lg mb-1"><%= m.subject %></h3>
              <p class="text-sm text-text-secondary line-clamp-2"><%= m.description || 'No description' %></p>
            </div>
            <div class="mt-4 pt-3 border-t border-stroke flex justify-between items-center text-xs text-muted font-mono">
              <span>Added <%= new Date(m.createdAt).toLocaleDateString() %></span>
            </div>
          </div>
        <% }) %>
      </div>
    </div>


    <!-- ════════════════════════════════════════════════════════════
         TIMELINE SECTION
    ════════════════════════════════════════════════════════════ -->
    <div id="timeline" class="tab-content max-w-5xl mx-auto space-y-8 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-text-primary">Timeline Events</h1>
      </div>

      <!-- Add Form -->
      <form action="/admin/api/timeline" method="POST" class="premium-card p-6 md:p-8 relative">
        <div class="absolute top-0 left-0 w-1 h-full bg-emerald-500 rounded-l-lg"></div>
        <h3 class="text-lg font-bold text-text-primary mb-6 flex items-center gap-2">Add Timeline Milestone</h3>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Year(s)</label>
            <input type="text" name="year" required class="premium-input text-sm" placeholder="e.g. 2021 - Present">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Role / Title</label>
            <input type="text" name="role" required class="premium-input text-sm" placeholder="Senior Educator">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Location / Institution</label>
            <input type="text" name="location" required class="premium-input text-sm" placeholder="ABC University">
          </div>
          <div>
            <label class="block text-xs text-muted mb-2 uppercase tracking-wide font-semibold">Order Index</label>
            <input type="number" name="orderIndex" value="0" class="premium-input text-sm font-mono">
          </div>
        </div>
        <div class="mt-8 flex justify-end">
          <button type="submit" class="premium-button bg-emerald-500 border-transparent text-white hover:bg-emerald-400 py-2.5 shadow-[0_0_20px_rgba(16,185,129,0.3)]">
            Add Milestone
          </button>
        </div>
      </form>

      <!-- List -->
      <div class="grid md:grid-cols-2 gap-4">
        <% timelineEvents.forEach(t=> { %>
          <div class="premium-card p-5 flex justify-between group hover:border-emerald-500/40">
            <div>
              <span class="text-[10px] bg-emerald-500/10 text-emerald-400 border border-emerald-500/20 px-2 py-0.5 rounded-full uppercase font-bold tracking-wider mb-2 inline-block"><%= t.year %></span>
              <h3 class="font-bold text-text-primary text-lg"><%= t.role %></h3>
              <p class="text-sm text-text-secondary mt-1"><%= t.location %></p>
              <p class="text-[10px] text-muted font-mono mt-3">Order: <%= t.orderIndex %></p>
            </div>
            <form action="/admin/api/timeline/<%= t.id %>/delete" method="POST" onsubmit="return confirm('Delete this timeline event?');">
              <button type="submit" class="text-xs font-semibold px-2 py-1 rounded bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-colors">✕</button>
            </form>
          </div>
        <% }) %>
      </div>
    </div>


    <!-- ════════════════════════════════════════════════════════════
         MESSAGES SECTION
    ════════════════════════════════════════════════════════════ -->
    <div id="messages" class="tab-content max-w-4xl mx-auto space-y-8 pb-20">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-text-primary">Inbox Messages</h1>
        <span class="px-3 py-1 bg-surface-2 border border-stroke rounded-full text-xs font-bold font-mono"><%= messages.length %> Total</span>
      </div>

      <div class="space-y-4">
        <% if (messages.length === 0) { %>
          <div class="premium-card py-16 text-center text-muted flex flex-col items-center justify-center">
            <svg class="w-12 h-12 mb-4 opacity-20" fill="currentColor" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2z"/></svg>
            <p>Your inbox is empty.</p>
          </div>
        <% } %>
        <% messages.forEach(m=> { %>
          <div class="premium-card p-6 flex flex-col gap-4 group">
            <div class="flex justify-between items-start border-b border-stroke pb-4">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-brand/10 text-brand font-bold flex items-center justify-center border border-brand/20 uppercase">
                  <%= m.name.charAt(0) %>
                </div>
                <div>
                  <h4 class="font-bold text-text-primary"><%= m.name %></h4>
                  <a href="mailto:<%= m.email %>" class="text-xs text-brand hover:underline"><%= m.email %></a>
                </div>
              </div>
              <div class="text-[10px] text-muted font-mono whitespace-nowrap">
                <%= new Date(m.createdAt).toLocaleString() %>
              </div>
            </div>
            <div>
              <% if (m.subject) { %>
                <h5 class="font-bold text-text-primary text-sm mb-2"><%= m.subject %></h5>
              <% } %>
              <p class="text-sm text-text-secondary whitespace-pre-wrap bg-surface-2 p-4 rounded-lg border border-stroke"><%= m.message %></p>
            </div>
            <div class="flex justify-end pt-2">
              <form action="/admin/api/messages/<%= m.id %>/delete" method="POST" onsubmit="return confirm('Delete message?');">
                <button type="submit" class="text-xs font-semibold px-3 py-2 rounded-lg bg-red-500/10 text-red-500 hover:bg-red-500 hover:text-white transition-colors flex items-center gap-1">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M19 13H5v-2h14v2z"/></svg>
                  Delete
                </button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    </div>

  </main>
  
  <!-- Overlay for mobile sidebar -->
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/50 backdrop-blur-sm z-30 hidden md:hidden"></div>

  <!-- Javascript for Tabs & Interactivity -->
  <script>
    document.addEventListener("DOMContentLoaded", function () {
      // Initialize SimpleMDE
      if(document.getElementById("blog-content-editor")) {
        new SimpleMDE({
          element: document.getElementById("blog-content-editor"),
          spellChecker: false,
          placeholder: "Write your amazing blog post here in Markdown..."
        });
      }

      // Tab Switching Logic
      const navBtns = document.querySelectorAll('.nav-btn');
      const tabContents = document.querySelectorAll('.tab-content');
      
      // Setup Initial State (Projects active)
      function setActiveTab(tabId) {
        // Reset all buttons
        navBtns.forEach(btn => {
          btn.classList.remove('text-brand', 'bg-brand/10', 'border-brand/20');
          btn.classList.add('text-text-secondary', 'border-transparent', 'hover:bg-surface-2', 'hover:text-text-primary');
        });
        
        // Hide all contents
        tabContents.forEach(content => {
          content.classList.remove('active');
        });
        
        // Activate selected button
        const activeBtn = document.querySelector(`.nav-btn[data-tab="${tabId}"]`);
        if (activeBtn) {
          activeBtn.classList.remove('text-text-secondary', 'border-transparent', 'hover:bg-surface-2', 'hover:text-text-primary');
          activeBtn.classList.add('text-brand', 'bg-brand/10', 'border-brand/20');
        }
        
        // Show selected content
        const activeContent = document.getElementById(tabId);
        if (activeContent) {
          activeContent.classList.add('active');
        }
        
        // Scroll to top
        document.querySelector('main').scrollTo({ top: 0, behavior: 'smooth' });
        
        // Close mobile sidebar if open
        closeSidebar();
      }

      // Add click listeners to tabs
      navBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          setActiveTab(btn.dataset.tab);
        });
      });

      // Mobile Sidebar Toggle
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      
      function openSidebar() {
        sidebar.classList.remove('hidden');
        sidebar.classList.remove('-translate-x-full');
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      
      function closeSidebar() {
        if(window.innerWidth < 768) {
          sidebar.classList.add('-translate-x-full');
          setTimeout(() => { sidebar.classList.add('hidden'); }, 300);
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }
      
      mobileBtn.addEventListener('click', openSidebar);
      overlay.addEventListener('click', closeSidebar);
      
      // Auto-hide mobile sidebar off-screen initially
      if(window.innerWidth < 768) {
        sidebar.classList.add('-translate-x-full');
      }
      
      // Handle window resize
      window.addEventListener('resize', () => {
        if(window.innerWidth >= 768) {
          sidebar.classList.remove('hidden', '-translate-x-full');
          overlay.classList.add('hidden');
          document.body.style.overflow = '';
        } else if (!overlay.classList.contains('hidden')) {
          // If it was open on mobile
        } else {
          sidebar.classList.add('hidden', '-translate-x-full');
        }
      });
    });
  </script>
</body>
</html>