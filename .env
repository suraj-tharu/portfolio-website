# ─── Runtime secrets ──────────────────────────────────────────────────────────
# IMPORTANT: Never commit this file to git!
# .gitignore already excludes it. Make sure it stays that way.

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
# Your key was previously exposed. ROTATE IT NOW at:
#   https://dash.cloudflare.com → My Profile → API Tokens → Manage (delete old, create new)
#
# After rotating, paste your NEW key below:
CLOUDFLARE_API_KEY=demo_key_12345

# ── PostgreSQL Database (free options below) ──────────────────────────────────
# Option A — Neon (recommended, generous free tier):
#   1. Sign up at https://neon.tech
#   2. Create a project → Copy the "Connection string"
#   3. Paste below:
#
# Option B — Supabase:
#   1. Sign up at https://supabase.com → New project → Settings → Database
#   2. Copy the "Connection string" (URI format)
#
# Option C — Railway: https://railway.app (add PostgreSQL plugin)
#
# If you do not have a database for development, leave this line commented out.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email Notifications ────────────────────────────────────────────────────────
# You'll receive an email every time someone submits the contact form.
#
# For Gmail (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → copy the 16-character code
#   4. Use it as EMAIL_PASS below (NOT your regular Gmail password)

EMAIL_SERVICE=gmail
EMAIL_USER=demo@example.com
EMAIL_PASS=demo_app_password
EMAIL_TO=demo@example.com


# This was inserted by `prisma init`:
# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

DATABASE_URL="file:./dev.db"
