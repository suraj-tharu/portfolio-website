# ─── Runtime secrets ──────────────────────────────────────────────────────────
# IMPORTANT: Never commit this file to git!
# .gitignore already excludes it. Make sure it stays that way.

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
# Your key was previously exposed. ROTATE IT NOW at:
#   https://dash.cloudflare.com → My Profile → API Tokens → Manage (delete old, create new)
#
# After rotating, paste your NEW key below:
CLOUDFLARE_API_KEY=YOUR_NEW_CLOUDFLARE_API_KEY_HERE

# ── PostgreSQL Database (free options below) ──────────────────────────────────
# Option A — Neon (recommended, generous free tier):
#   1. Sign up at https://neon.tech
#   2. Create a project → Copy the "Connection string"
#   3. Paste below:
#
# Option B — Supabase:
#   1. Sign up at https://supabase.com → New project → Settings → Database
#   2. Copy the "Connection string" (URI format)
#
# Option C — Railway: https://railway.app (add PostgreSQL plugin)
#
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Email Notifications ────────────────────────────────────────────────────────
# You'll receive an email every time someone submits the contact form.
#
# For Gmail (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Create an App Password for "Mail" → copy the 16-character code
#   4. Use it as EMAIL_PASS below (NOT your regular Gmail password)
#
EMAIL_SERVICE=gmail
EMAIL_USER=your.gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
EMAIL_TO=your.gmail@gmail.com
