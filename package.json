{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Backend for Suraj Portfolio",
  "main": "server.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "node node_modules/tailwindcss/lib/cli.js -i ./tailwind.input.css -o ./dist/tailwind.css --minify",
    "build:js": "npx esbuild src/index.js --bundle --minify --target=es2020 --outfile=dist/bundle.js",
    "watch:css": "node node_modules/tailwindcss/lib/cli.js -i ./tailwind.input.css -o ./dist/tailwind.css --watch",
    "watch:js": "npx esbuild src/index.js --bundle --target=es2020 --outfile=dist/bundle.js --watch",
    "build:frontend": "cd frontend && npm install && npm run build",
    "build": "npm run build:css && npm run build:js && npm run build:frontend",
    "dev:all": "concurrently \"nodemon server.js\" \"npm run watch:css\" \"npm run watch:js\"",
    "postinstall": "npm run prisma:generate",
    "test": "npm run test:e2e",
    "test:e2e": "npx playwright test",
    "lint": "eslint . --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dompurify": "^3.4.9",
    "dotenv": "^16.4.5",
    "ejs": "^6.0.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsdom": "^29.1.1",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.5",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.0",
    "openai": "^4.52.0",
    "socket.io": "^4.8.3",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.1",
    "nodemon": "^3.1.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.19"
  }
}
