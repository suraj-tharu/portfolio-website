{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Backend for Suraj Portfolio",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./dist/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./tailwind.input.css -o ./dist/tailwind.css --watch",
    "test": "node debug2.js",
    "lint": "eslint . --ext .js --ignore-path .gitignore"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "morgan": "^1.11.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.52.0",
    "pg": "^8.21.0",
    "puppeteer": "^25.1.0",
    "socket.io": "^4.8.3",
    "xss": "^1.0.15",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "tailwindcss": "^3.4.19"
  }
}
