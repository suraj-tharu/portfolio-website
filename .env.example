# .env.example — safe to commit, shows required keys without values
# Copy this to .env and fill in your real values

# Cloudflare Workers AI key (rotate at https://dash.cloudflare.com → My Profile → API Tokens)
CLOUDFLARE_API_KEY=

# PostgreSQL connection string (Neon: https://neon.tech | Supabase | Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Email notifications when contact form is submitted
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=your.email@gmail.com
